DJANGO_SECRET_KEY=replace-me-with-a-long-random-secret
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
DJANGO_TIME_ZONE=Europe/London
DJANGO_LOG_LEVEL=INFO

# Primary PostgreSQL connection string.
DATABASE_URL=postgresql://user:password@host:5432/barrelboss
DATABASE_FALLBACK_URL=
RENDER_EXTERNAL_DATABASE_URL=
DATABASE_SSL_REQUIRE=true
DATABASE_CONNECT_TIMEOUT=15

# Optional fallback PostgreSQL fields (used only if DATABASE_URL is not set)
POSTGRES_DB=taptrack
POSTGRES_USER=taptrack_user
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Outbound mail / password reset
DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DJANGO_EMAIL_HOST=localhost
DJANGO_EMAIL_PORT=25
DJANGO_EMAIL_HOST_USER=
DJANGO_EMAIL_HOST_PASSWORD=
DJANGO_EMAIL_USE_TLS=false
DJANGO_EMAIL_USE_SSL=false
DJANGO_EMAIL_TIMEOUT=10
DJANGO_DEFAULT_FROM_EMAIL=BarrelBoss <no-reply@localhost>
DJANGO_SERVER_EMAIL=BarrelBoss <no-reply@localhost>
PASSWORD_RESET_TIMEOUT=86400

# Auth and session hardening
ALLOW_DEMO_ACCOUNT_BOOTSTRAP=false
LOGIN_THROTTLE_FAILURE_LIMIT=5
LOGIN_THROTTLE_WINDOW_SECONDS=900
LOGIN_THROTTLE_LOCKOUT_SECONDS=900
SESSION_IDLE_TIMEOUT_SECONDS=1800
SESSION_COOKIE_AGE=43200
SESSION_EXPIRE_AT_BROWSER_CLOSE=true

# HTTPS, headers, and browser safety
DJANGO_SECURE_SSL_REDIRECT=true
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=true
DJANGO_SECURE_HSTS_PRELOAD=true
DJANGO_SECURE_REFERRER_POLICY=strict-origin-when-cross-origin
DJANGO_SECURE_CROSS_ORIGIN_OPENER_POLICY=same-origin

# Webhook and background intake limits
POS_WEBHOOK_MAX_BODY_BYTES=131072

# Web push notifications (staff shift allocation alerts)
# Generate VAPID keys before enabling in production.
WEB_PUSH_PUBLIC_KEY=
WEB_PUSH_PRIVATE_KEY=
WEB_PUSH_SUBJECT=mailto:alerts@barrelboss.local

# Local browser E2E settings
E2E_REQUIRE_BROWSER=false
E2E_HEADLESS=true

# Read-only hosted smoke settings (post-deploy)
SMOKE_BASE_URL=https://barrelboss.onrender.com
SMOKE_HEADLESS=true
SMOKE_MANAGER_USERNAME=
SMOKE_MANAGER_PASSWORD=
SMOKE_STAFF_USERNAME=
SMOKE_STAFF_PASSWORD=
SMOKE_LANDLORD_USERNAME=
SMOKE_LANDLORD_PASSWORD=

# Render production reminders:
# DJANGO_DEBUG=false
# DJANGO_ALLOWED_HOSTS=barrelboss.onrender.com
# DJANGO_CSRF_TRUSTED_ORIGINS=https://barrelboss.onrender.com
# RENDER_EXTERNAL_HOSTNAME=barrelboss.onrender.com
# DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# DJANGO_DEFAULT_FROM_EMAIL=BarrelBoss <no-reply@yourdomain.com>
